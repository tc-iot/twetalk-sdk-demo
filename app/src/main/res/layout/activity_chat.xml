<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light"
    tools:context=".chat.BaseChatActivity">

    <!-- 顶部工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/chat_toolbar_height"
        android:background="@color/primary_blue"
        app:title="@string/chat_title"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 连接状态栏 -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="@dimen/chat_status_bar_padding"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disconnected"
            android:textColor="@color/white"
            app:chipBackgroundColor="@color/error_red"
            app:chipIcon="@drawable/ic_disconnected"
            app:chipIconTint="@color/selector_icon_tint_white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAudioFormat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/chat_chip_margin_start"
            android:text="OPUS"
            android:textColor="@color/gray_text"
            app:chipBackgroundColor="@color/gray_medium"
            app:chipIcon="@drawable/ic_audio" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndChat"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="结束对话"
            android:textColor="@color/error_red"
            app:icon="@drawable/ic_end_call"
            app:iconTint="@color/selector_icon_tint_error" />

    </LinearLayout>

    <!-- 消息列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="@dimen/chat_message_list_padding"
        app:layout_constraintBottom_toTopOf="@id/audioControlPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintVertical_bias="1.0"
        tools:listitem="@layout/item_chat_message" />

    <!-- 音频控制面板 -->
    <LinearLayout
        android:id="@+id/audioControlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="@dimen/chat_control_panel_padding"
        app:layout_constraintBottom_toTopOf="@id/textInputPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 音频波形显示区域 -->
        <LinearLayout
            android:id="@+id/audioVisualizerContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/chat_audio_visualizer_height"
            android:layout_marginBottom="@dimen/chat_audio_visualizer_margin_bottom"
            android:background="@drawable/bg_audio_visualizer"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAudioStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/listening"
                android:textColor="@color/primary_blue"
                android:textSize="@dimen/chat_audio_status_text_size"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 录音控制按钮区域 -->
        <LinearLayout
            android:id="@+id/recordButtonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- 主录音按钮 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabRecord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/hold_to_speak"
                app:backgroundTint="@color/primary_blue"
                app:srcCompat="@drawable/ic_mic"
                app:tint="@color/white"
                app:fabSize="normal" />

        </LinearLayout>

        <!-- 提示文本 -->
        <TextView
            android:id="@+id/tvRecordHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/chat_record_hint_margin_top"
            android:text="@string/hold_to_speak"
            android:textColor="@color/gray_text"
            android:textSize="@dimen/chat_record_hint_text_size" />
    </LinearLayout>

    <!-- 文本发送区域 -->
    <LinearLayout
        android:id="@+id/textInputPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- 录音切换按钮 -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecordInText"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="@string/hold_to_speak"
            app:backgroundTint="@color/primary_blue"
            app:fabCustomSize="28dp"
            app:fabSize="mini"
            app:maxImageSize="16dp"
            app:srcCompat="@drawable/ic_mic"
            app:tint="@color/white" />

        <!-- 文本输入框 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            app:hintEnabled="false"
            app:boxBackgroundMode="outline"
            >

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:minLines="1"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 发送按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendText"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:enabled="false"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_send"
            app:iconSize="16dp"
            app:iconTint="@color/primary_blue" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B2000000"
        android:visibility="gone">

        <include
            android:id="@+id/loading"
            layout="@layout/layout_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent" />
    </FrameLayout>

    <!-- 视频聊天界面 -->
    <FrameLayout
        android:id="@+id/videoChatLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" >

        <include
            android:id="@+id/videoChat"
            layout="@layout/activity_video_chat" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>